# ═══════════════════════════════════════════════════════════════════════════════
# INTELLMEET BACKEND ENVIRONMENT CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════
#
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
#
# ═══════════════════════════════════════════════════════════════════════════════

# ─── SERVER CONFIGURATION ──────────────────────────────────────────────────────

# Environment: development, test, or production
NODE_ENV=development

# Server port (default: 5000)
PORT=5000

# ─── DATABASE ──────────────────────────────────────────────────────────────────

# MongoDB connection URI
# Local: mongodb://localhost:27017/intellmeet
# Atlas: mongodb+srv://user:password@cluster.mongodb.net/intellmeet?retryWrites=true
MONGO_URI=mongodb://localhost:27017/intellmeet

# ─── AUTHENTICATION & JWT ──────────────────────────────────────────────────────

# JWT secret for access tokens (REQUIRED, min 32 characters)
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# MUST be changed in production
JWT_SECRET=replace-with-a-secure-random-string-of-at-least-32-chars

# Access token expiration (default: 15m)
# Valid units: s, m, h, d (e.g., 15m, 1h, 7d)
JWT_EXPIRES_IN=15m

# Refresh token secret (REQUIRED in production, min 32 characters)
# Should be different from JWT_SECRET
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
REFRESH_TOKEN_SECRET=replace-with-a-different-secure-random-string

# Refresh token expiration (default: 7d)
REFRESH_TOKEN_EXPIRES_IN=7d

# ─── CORS & FRONTEND ──────────────────────────────────────────────────────────

# Frontend URL (for CORS and password reset/verification links)
# Development: http://localhost:5173
# Production: https://intellmeet.example.com
FRONTEND_URL=http://localhost:5173

# ─── OPTIONAL: ERROR TRACKING ──────────────────────────────────────────────────

# Sentry DSN for centralized error tracking
# Get from: https://sentry.io/
# Leave empty to disable Sentry integration
SENTRY_DSN=

# ─── OPTIONAL: EMAIL SERVICE ──────────────────────────────────────────────────
# Required for password reset, email verification, and notifications
# Leave empty to disable (reset/verification links logged to console)

# SMTP server hostname
SMTP_HOST=smtp.gmail.com

# SMTP server port (25=plain, 465=SSL, 587=TLS)
SMTP_PORT=587

# SMTP authentication username (usually email address)
SMTP_USER=noreply@intellmeet.com

# SMTP authentication password or app-specific password
# ⚠️ For Gmail: Use App Passwords, NOT your main password
# https://myaccount.google.com/apppasswords
SMTP_PASS=your-app-password-here

# Enable TLS encryption (true/false)
SMTP_TLS=true

# Email address to display in "From" field
SMTP_FROM_EMAIL=noreply@intellmeet.com

# Email address for admin alerts (optional)
ADMIN_EMAIL=admin@intellmeet.com

# ─── OPTIONAL: AWS S3 (FOR MEETING RECORDINGS) ────────────────────────────────
# Required if you want to store meeting recordings in AWS S3

AWS_REGION=us-east-1

# IAM user access key (create with S3 permissions only)
AWS_ACCESS_KEY_ID=your-aws-access-key

# IAM user secret access key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key

# S3 bucket name for recordings
AWS_S3_BUCKET=intellmeet-recordings

# ─── OPTIONAL: LOGGING & MONITORING ────────────────────────────────────────────

# Log level: error, warn, info, debug, trace
LOG_LEVEL=debug

# Enable HTTP request/response logging (true/false)
LOG_REQUESTS=true

# ═══════════════════════════════════════════════════════════════════════════════
# PRODUCTION DEPLOYMENT CHECKLIST
# ═══════════════════════════════════════════════════════════════════════════════
#
# Before deploying to production:
#
# ✅ NODE_ENV=production
# ✅ JWT_SECRET: Strong random string (openssl rand -hex 48)
# ✅ REFRESH_TOKEN_SECRET: Different from JWT_SECRET
# ✅ MONGO_URI: Production MongoDB Atlas cluster with auth
# ✅ FRONTEND_URL: Your production domain (https)
# ✅ SENTRY_DSN: Configured for error tracking
# ✅ SMTP_*: Configured for email services
# ✅ AWS_S3_*: S3 bucket created and credentials valid
# ✅ All secrets in environment (not in code)
# ✅ Database backups enabled
# ✅ HTTPS/TLS certificates installed
# ✅ CORS whitelist set to production domain only
# ✅ Rate limiting configured for expected traffic
# ✅ Monitoring and alerting enabled
#
# ═══════════════════════════════════════════════════════════════════════════════
# SECURITY BEST PRACTICES
# ═══════════════════════════════════════════════════════════════════════════════
#
# 🔐 Secrets Management:
#   - NEVER commit .env to git
#   - Use GitHub Actions Secrets for CI/CD
#   - Use AWS Secrets Manager / Parameter Store
#   - Use Kubernetes Secrets for container orchestration
#   - Use HashiCorp Vault for distributed teams
#
# 🔑 JWT Secrets:
#   - Generate with: openssl rand -hex 48
#   - Minimum 32 characters
#   - Unique for each environment
#   - Rotate periodically in production
#
# 🗄️ Database Security:
#   - Strong username/password
#   - Enable MongoDB authentication
#   - Enable encryption at rest
#   - IP whitelist to app servers only
#   - Daily automated backups
#   - Test restore procedures
#
# 📧 Email/SMTP:
#   - Use app-specific passwords (not main password)
#   - Gmail: https://myaccount.google.com/apppasswords
#   - Outlook: https://account.microsoft.com/security/app-passwords
#   - Enable TLS/SSL (SMTP_TLS=true)
#
# ☁️ AWS S3:
#   - Create dedicated IAM user with S3 permissions only
#   - Use bucket policies to restrict access
#   - Enable versioning and access logging
#   - Set object lock for compliance
#   - Configure lifecycle policies (archive old recordings)
#
# ═══════════════════════════════════════════════════════════════════════════════

